# SlotSmart backend — editor & analyzer rules.
# Cross-cutting C# style; per-file overrides go below.

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{json,yml,yaml,csproj,props,targets,xml,sln}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
# Prefer file-scoped namespaces.
csharp_style_namespace_declarations = file_scoped:warning
# Always use var when type is apparent.
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_elsewhere = true:suggestion
# Expression-bodied members where it improves clarity.
csharp_style_expression_bodied_methods = when_on_single_line:silent
csharp_style_expression_bodied_constructors = false:none
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_indexers = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion
# Pattern matching.
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning
# Nullable reference types are project-wide on.
dotnet_diagnostic.CS8600.severity = error
dotnet_diagnostic.CS8601.severity = error
dotnet_diagnostic.CS8602.severity = error
dotnet_diagnostic.CS8603.severity = error
dotnet_diagnostic.CS8604.severity = error
dotnet_diagnostic.CS8618.severity = error
# Unused using directives — error for cleanliness.
dotnet_diagnostic.IDE0005.severity = error
# Code-style 'must use namespace' enforcement.
dotnet_diagnostic.IDE0161.severity = error
